# Copy to .env and fill in real values. .env is gitignored; this template is not.
#   cp .env.example .env
# Load it when running examples:
#   uv run --env-file .env python examples/spider_cloud_proxy.py

# spider.cloud API key (used as the proxy username). Get it from your dashboard.
SPIDER_API_KEY=sk-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: a generic proxy URL for examples/proxy.py
# PROXY_URL=http://user:pass@host:8080
